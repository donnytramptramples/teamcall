<!DOCTYPE html>
<html lang="en">
<head>
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://unpkg.com"></script>
    <style>
        :root { --bg: #1b1e20; --panel: #232629; --accent: #3daee9; --danger: #da4453; --border: #31363b; }
        body { background: var(--bg); color: #eff0f1; font-family: 'Inter', sans-serif; margin: 0; display: flex; height: 100vh; overflow: hidden; }
        
        #video-container { flex: 1; display: flex; flex-direction: column; position: relative; }
        #video-grid { flex: 1; display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 15px; padding: 20px; align-content: center; justify-items: center; overflow-y: auto; }
        video { width: 100%; max-width: 480px; height: auto; aspect-ratio: 4/3; object-fit: cover; border-radius: 10px; border: 2px solid var(--border); background: #000; transform: scaleX(-1); box-shadow: 0 4px 15px rgba(0,0,0,0.3); }

        .control-bar { height: 80px; background: rgba(35, 38, 41, 0.95); display: flex; align-items: center; justify-content: center; gap: 20px; border-top: 1px solid var(--border); backdrop-filter: blur(10px); }
        .icon-btn { background: var(--panel); border: 1px solid var(--border); color: #eff0f1; width: 50px; height: 50px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.3s; font-size: 12px; font-weight: bold; }
        .icon-btn:hover { border-color: var(--accent); color: var(--accent); background: #2a2e32; }
        .icon-btn.active { color: var(--accent); border-color: var(--accent); box-shadow: 0 0 10px rgba(61, 174, 233, 0.3); }
        .leave-btn { background: var(--danger); border: none; width: auto; padding: 0 25px; border-radius: 25px; }
        .leave-btn:hover { background: #c0392b; color: white; }
        #end-btn { display: none; background: #96281b; }

        #sidebar { width: 320px; background: var(--panel); border-left: 1px solid var(--border); display: flex; flex-direction: column; }
        #chat-header { padding: 20px; font-weight: bold; border-bottom: 1px solid var(--border); font-size: 14px; letter-spacing: 1px; }
        #messages { flex: 1; padding: 15px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; scrollbar-width: thin; }
        .msg { background: #31363b; padding: 10px; border-radius: 8px; max-width: 85%; font-size: 13px; border-left: 3px solid var(--accent); }
        .msg b { color: var(--accent); display: block; margin-bottom: 4px; }
        #chat-input { background: #1b1e20; border: none; border-top: 1px solid var(--border); padding: 20px; color: white; outline: none; font-size: 14px; }
    </style>
</head>
<body>
    <div id="video-container">
        <div id="video-grid"></div>
        <div class="control-bar">
            <button class="icon-btn" onclick="toggle('audio')">Mic</button>
            <button class="icon-btn" onclick="toggle('video')">Cam</button>
            <button class="icon-btn" onclick="shareScreen()">Share</button>
            <button class="icon-btn" onclick="copyInvite()">Invite</button>
            <button class="icon-btn leave-btn" onclick="location.href='/'">Leave</button>
            <button id="end-btn" class="icon-btn leave-btn" onclick="endCall()">End for All</button>
        </div>
    </div>
    <div id="sidebar">
        <div id="chat-header">IN-CALL MESSAGES</div>
        <div id="messages"></div>
        <input type="text" id="chat-input" placeholder="Send a message to everyone...">
    </div>

    <script>
        const socket = io('/');
        const videoGrid = document.getElementById('video-grid');
        const peer = new Peer(undefined, { host: '0.peerjs.com', port: 443, secure: true });
        const myVideo = document.createElement('video');
        myVideo.muted = true;
        const uName = localStorage.getItem('uName') || "User";
        let myStream;

        navigator.mediaDevices.getUserMedia({ video: true, audio: true }).then(stream => {
            myStream = stream;
            addVideo(myVideo, stream);
            peer.on('call', call => {
                call.answer(stream);
                const video = document.createElement('video');
                call.on('stream', userStream => addVideo(video, userStream));
            });
            socket.on('user-connected', (userId) => connect(userId, stream));
        });

        peer.on('open', id => socket.emit('join-room', "<%= roomId %>", id, uName));
        socket.on('permissions', isHost => { if(isHost) document.getElementById('end-btn').style.display='flex'; });
        socket.on('meeting-ended', () => { alert("Meeting ended by host"); location.href='/'; });

        function connect(userId, stream) {
            const call = peer.call(userId, stream);
            const video = document.createElement('video');
            call.on('stream', userStream => addVideo(video, userStream));
        }

        function addVideo(v, s) {
            v.srcObject = s; v.addEventListener('loadedmetadata', () => v.play());
            videoGrid.append(v);
        }

        function toggle(type) {
            const track = type === 'audio' ? myStream.getAudioTracks()[0] : myStream.getVideoTracks()[0];
            track.enabled = !track.enabled;
            event.target.classList.toggle('active');
        }

        function copyInvite() {
            navigator.clipboard.writeText(window.location.href);
            alert("Invite link copied to clipboard.");
        }

        function endCall() { if(confirm("End meeting for everyone?")) socket.emit('end-meeting'); }

        const input = document.getElementById('chat-input');
        input.addEventListener('keydown', e => {
            if(e.key === 'Enter' && input.value) { socket.emit('message', input.value); input.value = ''; }
        });
        socket.on('createMessage', (msg, user) => {
            document.getElementById('messages').innerHTML += `<div class="msg"><b>${user}</b>${msg}</div>`;
            const msgs = document.getElementById('messages');
            msgs.scrollTop = msgs.scrollHeight;
        });

        async function shareScreen() {
            const screenStream = await navigator.mediaDevices.getDisplayMedia({ cursor: true });
            const screenVideo = document.createElement('video');
            addVideo(screenVideo, screenStream);
            screenStream.getVideoTracks()[0].onended = () => screenVideo.remove();
        }
    </script>
</body>
</html>
