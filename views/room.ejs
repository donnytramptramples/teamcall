<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <script src="/socket.io/socket.io.js"></script>
    <!-- PeerJS loaded synchronously to fix "Peer not defined" -->
    <script src="https://unpkg.com"></script>
    <style>
        body { background: #1b1e20; color: #eff0f1; font-family: sans-serif; margin: 0; display: flex; height: 100vh; overflow: hidden; }
        #main { flex: 1; display: flex; flex-direction: column; background: #232629; position: relative; }
        #video-grid { flex: 1; display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 15px; padding: 20px; overflow-y: auto; align-content: center; }
        video { width: 100%; border-radius: 8px; border: 2px solid #31363b; background: #000; transform: scaleX(-1); }
        .controls { height: 80px; background: #2a2e32; display: flex; align-items: center; justify-content: center; gap: 15px; border-top: 1px solid #31363b; }
        button { background: #31363b; color: white; border: 1px solid #454a4f; padding: 10px 20px; border-radius: 5px; cursor: pointer; transition: 0.2s; font-weight: bold; }
        button:hover { background: #3daee9; border-color: #3daee9; }
        .end-btn { background: #da4453; display: none; border: none; }
        #sidebar { width: 300px; background: #232629; border-left: 1px solid #31363b; display: flex; flex-direction: column; }
        #msgs { flex: 1; padding: 15px; overflow-y: auto; font-size: 13px; }
        #chat-input { background: #1b1e20; border: none; border-top: 1px solid #31363b; padding: 20px; color: white; outline: none; }
    </style>
</head>
<body>
    <div id="main">
        <div id="video-grid"></div>
        <div class="controls">
            <button onclick="copy()">Invite</button>
            <button onclick="toggleMic()">Mic</button>
            <button onclick="toggleVid()">Cam</button>
            <button onclick="share()">Share Screen</button>
            <button onclick="location.href='/'">Leave</button>
            <button id="end-btn" class="end-btn" onclick="end()">End Call</button>
        </div>
    </div>
    <div id="sidebar">
        <div style="padding:15px; border-bottom:1px solid #31363b; font-weight:bold;">CHAT</div>
        <div id="msgs"></div>
        <input type="text" id="chat-input" placeholder="Type message...">
    </div>

    <script>
        const socket = io('/');
        const grid = document.getElementById('video-grid');
        
        // PeerJS Cloud Config for UK-HK Stability
        const peer = new Peer(undefined, { host: '0.peerjs.com', port: 443, secure: true });
        
        const myVid = document.createElement('video'); myVid.muted = true;
        const uName = localStorage.getItem('uName') || "User";
        let myStream;

        navigator.mediaDevices.getUserMedia({ video: true, audio: true }).then(s => {
            myStream = s; add(myVid, s);
            peer.on('call', c => {
                c.answer(s);
                const v = document.createElement('video');
                c.on('stream', us => add(v, us));
            });
            socket.on('user-connected', id => {
                const c = peer.call(id, s);
                const v = document.createElement('video');
                c.on('stream', us => add(v, us));
            });
        });

        peer.on('open', id => socket.emit('join-room', "<%= roomId %>", id, uName));
        socket.on('permissions', h => { if(h) document.getElementById('end-btn').style.display='block'; });
        socket.on('meeting-ended', () => { alert("Host ended meeting"); location.href='/'; });

        function add(v, s) {
            v.srcObject = s; v.addEventListener('loadedmetadata', () => v.play());
            grid.append(v);
        }

        function toggleMic() { myStream.getAudioTracks()[0].enabled = !myStream.getAudioTracks()[0].enabled; }
        function toggleVid() { myStream.getVideoTracks()[0].enabled = !myStream.getVideoTracks()[0].enabled; }
        function copy() { navigator.clipboard.writeText(location.href); alert("Invite Link Copied"); }
        function end() { socket.emit('end-meeting'); }

        const inp = document.getElementById('chat-input');
        inp.addEventListener('keydown', e => {
            if(e.key === 'Enter' && inp.value) { socket.emit('message', inp.value); inp.value = ''; }
        });
        socket.on('createMessage', (m, u) => {
            document.getElementById('msgs').innerHTML += `<div><b>${u}:</b> ${m}</div>`;
        });

        async function share() {
            try {
                const sc = await navigator.mediaDevices.getDisplayMedia({ video: true });
                const v = document.createElement('video'); add(v, sc);
                sc.getVideoTracks()[0].onended = () => v.remove();
            } catch(e) { console.error(e); }
        }
    </script>
</body>
</html>
