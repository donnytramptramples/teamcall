<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Video Portal</title>
    <style>
        body { background: #1b1e20; color: #eff0f1; font-family: sans-serif; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        .card { background: #232629; padding: 40px; border: 1px solid #31363b; border-radius: 8px; width: 350px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        input { background: #1b1e20; border: 1px solid #454a4f; color: white; padding: 12px; width: 85%; margin-bottom: 15px; border-radius: 4px; outline: none; }
        button { background: #3daee9; color: white; border: none; padding: 12px; border-radius: 4px; cursor: pointer; width: 93%; font-weight: bold; margin-top: 10px; transition: 0.2s; }
        button:hover { background: #2980b9; }
        .sec { background: #31363b; border: 1px solid #454a4f; }
    </style>
</head>
<body>
    <div class="card">
        <h2 style="color: #3daee9;">Secure Meeting</h2>
        <input type="text" id="name" placeholder="Your Name">
        <input type="text" id="code" placeholder="Meeting ID">
        <button onclick="enter('c')">Join Meeting</button>
        <button class="sec" onclick="enter('r')">Create Instant Room</button>
    </div>
    <script>
        function enter(t) {
            const n = document.getElementById('name').value || 'Guest';
            let c = document.getElementById('code').value;
            if(t === 'r') c = Math.random().toString(36).substring(7);
            if(!c) return alert("ID Required");
            localStorage.setItem('uName', n);
            window.location.href = `/room/${c}`;
        }
    </script>
</body>
</html>
